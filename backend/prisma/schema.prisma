generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id            String          @id @default(uuid())
  type          TransactionType
  description   String
  amount        Decimal
  annualRate    Decimal?
  category      String
  date          DateTime
  paymentMethod String
  receiptUrl    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}
